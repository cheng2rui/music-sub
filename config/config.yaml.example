# music-sub config template
# Copy to config.yaml and fill in your own credentials.

sites:
  mteam:
    enabled: false
    url: "https://kp.m-team.cc"
    api_key: ""        # M-Team API key (Profile → Security → API Key)
    token: ""          # JWT token (optional)
    cookie: ""

  opencd:
    enabled: false
    url: "https://open.cd"
    api_key: ""
    token: ""
    cookie: ""         # browser Cookie header

  ptclub:
    enabled: false
    url: "https://pt.sjtu.edu.cn"
    api_key: ""
    token: ""
    cookie: ""

  dismusic:
    enabled: false
    url: "https://dis.music"
    api_key: ""
    token: ""
    cookie: ""

qbittorrent:
  # Docker Compose bundled qBittorrent service:
  host: "http://qbittorrent:8080"
  # If using an external qBittorrent, set e.g. http://192.168.1.10:8080
  username: "admin"
  password: ""
  category: "music"
  save_path: "/downloads/music"
  tag: "music-sub"

paths:
  library: "/music"
  structure: "{artist}/{album}"
  downloads: "/downloads/music"

scraper:
  sources:
    - qqmusic
    - netease
    - kugou
    - migu
    - musicbrainz
  embed_cover: true
  cover_max_size: 0          # 0 = original size; >0 px = resize to this width
  save_cover_file: true      # write cover.jpg to album dir
  save_lyrics: true
  save_lyrics_to_tag: true
  save_lyrics_file: true     # write .lrc next to audio
  save_nfo: false            # write album.nfo for Kodi/Jellyfin
  rename_file: false
  rename_template: "${track} - ${title}"
  overwrite_tag: false       # skip already-tagged files when false
  break_hardlink_before_tag: true  # copy-on-write before tag/sidecar writes to keep PT seed files unchanged

scheduler:
  search_interval_minutes: 30
  check_complete_interval_minutes: 5
  cleanup_scan_enabled: true
  cleanup_scan_interval_hours: 24

notify:
  telegram:
    enabled: false
    bot_token: ""
    chat_id: ""
    on_download_added: false
    on_download_complete: true
    on_scrape_complete: true
    on_error: true
    on_cleanup_candidates: true

auth:
  username: "888"
  # password_hash is SHA-256 of the password. Default password: 888
  password_hash: "5e968ce47ce4a17e3823c29332a39d049a8d0afb08d157eb6224625f92671a51"
